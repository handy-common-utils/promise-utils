{
  "include": [
    "src"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "lib": [
      "es2021"
    ],
    "types": [
      "node"
    ],
    "target": "es2017",
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
  }
}